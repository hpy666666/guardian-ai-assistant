# ============================================================
# 敏感配置文件（绝对不能上传）
# ============================================================
.env
**/.env
**/data/.config.yaml
**/.config.yaml

# ============================================================
# Python
# ============================================================
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ============================================================
# 模型文件（体积过大）
# ============================================================
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.npz
*.rknn
models/
*/models/
**/models/

# ============================================================
# 音频/视频/临时输出
# ============================================================
*.wav
*.mp3
*.pcm
*.mp4
*.avi
*.mkv
tmp/
*/tmp/
**/tmp/
# 例外：保留压缩后的演示视频（37MB，可上传）
!image/result_vedio/fall_result_low.mp4

# ============================================================
# 图片与演示素材（image 目录）
# ============================================================
