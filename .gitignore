# ============================================================
# STM32 / RT-Thread
# ============================================================
# RT-Thread 完整官方源码，不属于本项目代码
guardian_f407/rt-thread/
# STM32 第三方库（CMSIS、HAL Driver 等）
guardian_f407/libraries/
guardian_f407/packages/
# 编译产物
guardian_f407/build/
guardian_f407/Debug/
guardian_f407/.sconsign.dblite
guardian_f407/rtconfig.pyc
**/*.o
**/*.d
**/*.axf
**/*.map
**/*.elf
**/*.hex

# ============================================================
# ESP32 (ESP-IDF)
# ============================================================
# ESP-IDF 编译产物（体积极大）
guardian_esp32_ai/build/
guardian_esp32_ai/managed_components/
guardian_esp32_ai/*.bin
guardian_esp32_ai/nvs.bin
guardian_esp32_ai/wifi_nvs.bin
guardian_esp32_ai/dependencies.lock

# ============================================================
# xiaozhi-esp32-server（第三方开源项目，仅保留我们的配置）
# ============================================================
guardian_server/main/xiaozhi-server/
# 例外：保留我们自定义的配置文件（用 ! 取消忽略）
!guardian_server/main/xiaozhi-server/config.yaml
!guardian_server/main/xiaozhi-server/requirements.txt

