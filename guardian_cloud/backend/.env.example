# ============================================================
# EMQX Cloud 配置（从你的控制台复制）
# ============================================================
MQTT_BROKER=your_emqx_broker_host
MQTT_PORT=8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_TLS=true

# ============================================================
# InfluxDB Cloud 配置
# ============================================================
INFLUX_URL=https://your-region.aws.cloud2.influxdata.com/
INFLUX_TOKEN=your_influxdb_token
INFLUX_ORG=your_org_name
INFLUX_BUCKET=guardian

# ============================================================
# Server酱 微信推送
# 申请地址：https://sct.ftqq.com/
# ============================================================
SERVERCHAN_KEY=your_serverchan_key

# ============================================================
# AI 语音助手配置
# ============================================================

# WebSocket 端口（ESP32 连接此端口）
AI_WS_PORT=8765

# 通义千问 API Key
# 申请地址：https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key

# DeepSeek API Key
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# Edge TTS 语音（微软免费在线TTS，无需API Key）
TTS_VOICE=zh-CN-XiaoxiaoNeural

# InfluxDB 设备ID（与 wifi_config.csv 的 mqtt/device_id 一致）
INFLUX_DEVICE_ID=001
